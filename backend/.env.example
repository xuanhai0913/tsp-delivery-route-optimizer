PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173,https://maps.hailamdev.space

# Prefer DATABASE_URL. DATABASE_PUBLIC_URL is supported for Railway public proxy URLs.
DATABASE_URL=
DATABASE_PUBLIC_URL=
DATABASE_SSL=false

# auto = PostgreSQL when configured and seeded, otherwise JSON samples.
# database = require PostgreSQL.
# json = force data/samples/*.json.
DATASET_SOURCE=auto
